{
  "name": "@llm-ports/observability-contract",
  "version": "0.1.0-alpha.28",
  "description": "Standalone data contract for LLM observability: event envelope, correlation model, lifecycle events, error info, cache stats, prompt fingerprint, evaluation refs, capture policy, W3C Trace Context + Baggage. Zero runtime dependencies on @llm-ports/core so non-port callers can emit conformant events without pulling in the registry.",
  "license": "MIT",
  "author": "Babak Abbaschian",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "test-vectors",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nanoid": "^5.0.9"
  },
  "peerDependencies": {
    "zod": ">=3.24.0 <5"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baabakk/llm-ports.git",
    "directory": "packages/observability-contract"
  },
  "keywords": [
    "llm",
    "ai",
    "typescript",
    "observability",
    "telemetry",
    "opentelemetry",
    "genai-semconv",
    "event-contract",
    "correlation",
    "prompt-fingerprint",
    "cache-stats"
  ],
  "homepage": "https://github.com/baabakk/llm-ports#readme",
  "bugs": {
    "url": "https://github.com/baabakk/llm-ports/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
