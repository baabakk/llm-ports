{
  "name": "@llm-ports/adapter-anthropic",
  "version": "0.1.0-alpha.6",
  "description": "Direct @anthropic-ai/sdk adapter for llm-ports. Implements LLMPort with prompt caching, vision, and tool use support for Claude models.",
  "license": "MIT",
  "author": "Babak Abbaschian",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@llm-ports/core": "workspace:*",
    "zod-to-json-schema": "^3.24.1"
  },
  "peerDependencies": {
    "zod": ">=3.24.0 <5"
  },
  "devDependencies": {
    "@llm-ports/adapter-contract-tests": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baabakk/llm-ports.git",
    "directory": "packages/adapter-anthropic"
  },
  "homepage": "https://github.com/baabakk/llm-ports/tree/main/packages/adapter-anthropic#readme",
  "bugs": {
    "url": "https://github.com/baabakk/llm-ports/issues"
  },
  "keywords": [
    "llm",
    "ai",
    "typescript",
    "anthropic",
    "claude",
    "claude-haiku",
    "claude-sonnet",
    "claude-opus",
    "ai-sdk",
    "generative-ai",
    "llm-ports",
    "llm-adapter",
    "llm-routing",
    "llm-fallback",
    "prompt-caching",
    "vision",
    "tool-use",
    "function-calling",
    "multi-provider",
    "cost-control"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
