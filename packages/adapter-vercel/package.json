{
  "name": "@llm-ports/adapter-vercel",
  "version": "0.0.0",
  "description": "Vercel AI SDK adapter for llm-ports. Migration path for users already on @ai-sdk/*. Bring your own Vercel-configured models; the adapter handles the LLMPort plumbing.",
  "license": "MIT",
  "author": "Babak Abbaschian",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@llm-ports/core": "workspace:*",
    "ai": "^4.3.19"
  },
  "devDependencies": {
    "@llm-ports/adapter-contract-tests": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baabakk/llm-ports.git",
    "directory": "packages/adapter-vercel"
  },
  "keywords": ["llm", "ai", "vercel-ai-sdk", "ai-sdk", "migration", "llm-ports", "adapter"],
  "engines": {
    "node": ">=18.0.0"
  }
}
