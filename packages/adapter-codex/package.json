{
  "name": "@llm-ports/adapter-codex",
  "version": "0.1.0-alpha.28",
  "description": "Subprocess-driven adapter for OpenAI Codex CLI. Runs `codex exec --json` as a subprocess, parses its JSON event stream, and emits @llm-ports contract events. Shape A: passthrough governance (operator supplies OpenAI credentials to codex directly; @llm-ports does NOT route the LLM traffic).",
  "license": "MIT",
  "author": "Babak Abbaschian",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@llm-ports/core": "workspace:*",
    "@llm-ports/observability-contract": "workspace:*"
  },
  "devDependencies": {
    "@llm-ports/core": "workspace:*",
    "@llm-ports/observability-contract": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baabakk/llm-ports.git",
    "directory": "packages/adapter-codex"
  },
  "keywords": [
    "llm",
    "ai",
    "codex",
    "openai",
    "agent",
    "subprocess",
    "llm-ports",
    "adapter"
  ],
  "homepage": "https://github.com/baabakk/llm-ports#readme",
  "bugs": {
    "url": "https://github.com/baabakk/llm-ports/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
