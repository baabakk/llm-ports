{
  "name": "llm-ports-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Provider-agnostic LLM architecture for TypeScript. Multi-provider routing, USD cost gating, fallback chains, typed capability factories, tool-use security primitives.",
  "repository": {
    "type": "git",
    "url": "https://github.com/baabakk/llm-ports.git"
  },
  "license": "MIT",
  "author": "Babak Abbaschian",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "pretest": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages --ext .ts",
    "format": "prettier --write \"packages/**/*.{ts,tsx,md,json}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=18.0.0"
  }
}
