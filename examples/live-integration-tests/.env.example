# Required for the canonical live tests (smoke, smoke:anthropic, smoke:chain, smoke:multi, smoke:vision)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — for smoke:compat (set any subset; missing ones are skipped silently)
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
# CLARIFAI_PAT=
# SAMBANOVA_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=

# Optional — for smoke:vision against Gemini (currently skipped if unset)
# GOOGLE_API_KEY=
